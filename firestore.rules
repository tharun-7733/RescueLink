rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Community Posts ──────────────────────────────────────────────────
    // Anyone authenticated can read all posts.
    // Only authenticated users can create posts (must own the post).
    // Only the document author can delete their own post.
    // Any authenticated user can update likes/likedBy/comments counts.
    match /community_posts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 280
        && request.resource.data.likes == 0
        && request.resource.data.comments == 0;

      allow update: if request.auth != null
        // Only allow updating likes/likedBy and comments (not content/author)
        && request.resource.data.author    == resource.data.author
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.content   == resource.data.content;

      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }
  }
}
